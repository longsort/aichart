# AI 채팅용 API 키 (서버 전용, 클라이언트에 노출되지 않음)
# 복사 후 .env.local 로 저장하고 값만 채우세요.

# ChatGPT (선택: 없으면 AI 대화 패널에서 브라우저에 키 입력 가능)
OPENAI_API_KEY=sk-...

# Gemini (필수: Gemini / Dual 사용 시). GOOGLE_API_KEY 로 대체 가능
GEMINI_API_KEY=

# 앱·API 접근 로그인 (미설정 시 기본: aichart / longshort)
# 운영에서는 반드시 변경하고 APP_SESSION_SECRET 도 임의 긴 문자열로 설정하세요.
# APP_BRIEFING_LOGIN_USER=aichart
# APP_BRIEFING_LOGIN_PASSWORD=longshort
# APP_SESSION_SECRET=랜덤-긴-문자열

# --- VPS 배포 (예: 167.179.119.140) ---
# npm run start → start.js 가 Next(PORT) + 캔들 서버(SERVER_PORT) 함께 기동
# PORT=3000
# SERVER_PORT=3001
# Next만 띄우려면: npm run start:next-only (캔들 API는 별도 필요)
# 캔들 서버 바인드: 기본 127.0.0.1 (분리 배포 시 CANDLE_SERVER_HOST=0.0.0.0 + CANDLES_SERVER_URL)
# CANDLE_SERVER_HOST=127.0.0.1
# CANDLES_SERVER_URL=http://127.0.0.1:3001
# HTTPS 리버스프록시 뒤면 쿠키 Secure: APP_USE_HTTPS=true
# next dev 에서 IP 접속 시 origin: NEXT_ALLOWED_DEV_ORIGINS=http://167.179.119.140:3000
# Python 엔진 쓰는 경우 (같은 서버): PYTHON_ENGINE_URL=http://127.0.0.1:8000

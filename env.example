# Discord 웹훅 (선택)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# 일반 웹훅 (선택)
WEBHOOK_URL=https://...

# Python 분석 엔진 (선택). 서버에서 localhost 대신 127.0.0.1 권장
PYTHON_ENGINE_URL=http://127.0.0.1:8000

# VPS: npm start = start.js (Next PORT + 캔들 SERVER_PORT)
# PORT=3000
# SERVER_PORT=3001
# APP_SESSION_SECRET=운영용-긴-랜덤
# NEXT_ALLOWED_DEV_ORIGINS=http://YOUR_IP:3000

# AI 채팅 (선택). OPENAI 없으면 UI에서 브라우저 키 입력 가능
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=...

# 선택: AI 사용 전 앱 로그인 (둘 다 설정 시에만 검증)
# APP_BRIEFING_LOGIN_USER=
# APP_BRIEFING_LOGIN_PASSWORD=
